[Unit]
Description=Kuma Data Plane Proxy
After=network-online.target
Wants=network-online.target

[Service]
User=kuma-dp
Group=kuma-dp
Type=simple
WorkingDirectory=/var/lib/kuma
ExecStart=/usr/local/bin/kuma-dp run \
  --cp-address=https://kuma-control-plane.kuma-system.svc:{{ kuma_vm_bootstrap_port }} \
  --dataplane-file=/etc/kuma/dp.yaml \
  --dataplane-token-file=/etc/kuma/kuma-dp-token \
  --ca-cert-file=/etc/kuma/kuma-ca.crt
Restart=on-failure
RestartSec=5s
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
