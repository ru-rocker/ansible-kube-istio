# Cluster settings for VM registration
ISTIO_META_ENV_AUTO_REGISTER=true
ISTIO_META_AUTO_REGISTER_GROUP={{ vm_auto_register_group }}
ISTIO_META_NETWORK={{ vm_network }}
CANONICAL_SERVICE={{ vm_canonical_service }}
ISTIO_META_WORKLOAD_NAME={{ inventory_hostname }}
ISTIO_META_NAMESPACE={{ vm_namespace }}
ISTIO_NAMESPACE={{ vm_namespace }}
ISTIO_SERVICE={{ vm_canonical_service }}
CA_ADDR=istiod.istio-system.svc:{{ vm_bootstrap_port }}
ISTIO_META_DNS_CAPTURE={{ vm_dns_capture | lower }}
ISTIO_META_DNS_AUTO_ALLOCATE={{ vm_dns_auto_allocate | lower }}
ISTIO_INBOUND_PORTS={{ vm_inbound_ports }}
ISTIO_SERVICE_CIDR={{ vm_service_cidr }}
